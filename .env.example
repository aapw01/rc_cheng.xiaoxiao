# 运行环境。
# 可选值：
# - local：本地开发 / 本地测试环境。CORS_ALLOWED_ORIGINS 为空时默认允许 Vite 开发地址。
# - production：生产环境。必须使用非默认 API_KEY；CORS_ALLOWED_ORIGINS 为空时不允许任何浏览器来源。
APP_ENV=local

# API 认证密钥，用于业务系统调用接口和运维 API。
# 调用时放在 X-API-Key 请求头中。生产环境必须修改默认值。
API_KEY=dev-api-key

# /ops 运维 Web 控制台登录密码。
# 与 API_KEY 独立，在浏览器登录页输入。
OPS_PASSWORD=dev-ops-password

# 浏览器跨域调用 API 的来源白名单，多个来源用英文逗号分隔。
# 示例：CORS_ALLOWED_ORIGINS=https://ops.example.com,http://localhost:5173
# 空值行为：
# - local：默认允许 http://localhost:5173 和 http://127.0.0.1:5173
# - production：不允许任何浏览器来源
CORS_ALLOWED_ORIGINS=

# SQLAlchemy 异步数据库连接地址。
# 本地直接运行 Python 时通常使用 localhost；Docker Compose 会覆盖为 postgres:5432。
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/notifications

# Dramatiq 消息队列使用的 Redis 地址。
# 本地直接运行 Python 时通常使用 localhost；Docker Compose 会覆盖为 redis:6379。
REDIS_URL=redis://localhost:6379/0

# 每条通知任务的总投递次数。
# 可选值：
# - 1：只投递一次，不自动重试
# - N（N > 1）：最多尝试 N 次，超过后标记为 failed
# - -1：无限重试
DEFAULT_MAX_ATTEMPTS=6

# 请求下游供应商 HTTP API 的超时时间，单位秒。
# 覆盖 httpx 的连接、读取、写入阶段。
HTTP_REQUEST_TIMEOUT_SECONDS=10

# Worker actor 单次执行的总时长上限，单位秒。
# 建议大于 HTTP_REQUEST_TIMEOUT_SECONDS；这是防止 DB、adapter、HTTP 路径卡住的兜底保护。
# 如果命中该限制，Dramatiq 可能中断 actor，并留下 stuck delivering 任务，需要人工处理。
ACTOR_TIME_LIMIT_SECONDS=30

# POST /api/notifications 接受的最大请求体大小，单位字节。
# 超过该限制会返回 413 payload_too_large。
MAX_PAYLOAD_BYTES=65536

# CRM 供应商凭证和接口地址。
# 本地使用 docker compose --profile mock 做端到端测试时，使用：
# PROVIDER_CRM_BASE_URL=http://mock-vendor:9000
PROVIDER_CRM_API_KEY=dev-crm-key
PROVIDER_CRM_BASE_URL=https://crm.vendor.test

# Ads 供应商凭证和接口地址。
# 示例 adapter 会把 PROVIDER_ADS_BEARER_TOKEN 作为 Bearer Token 发送。
PROVIDER_ADS_BEARER_TOKEN=dev-ads-token
PROVIDER_ADS_BASE_URL=https://ads.vendor.test

# Inventory 供应商凭证和接口地址。
# 示例 adapter 会把 PROVIDER_INVENTORY_API_KEY 作为供应商 API Key 发送。
PROVIDER_INVENTORY_API_KEY=dev-inventory-key
PROVIDER_INVENTORY_BASE_URL=https://inventory.vendor.test
