# API
# Set APP_ENV=production only with a non-default API_KEY.
APP_ENV=local
API_KEY=dev-api-key
OPS_PASSWORD=dev-ops-password
# Comma-separated origins. Local defaults to Vite dev origins when empty; production defaults to none.
CORS_ALLOWED_ORIGINS=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/notifications
REDIS_URL=redis://localhost:6379/0
DEFAULT_MAX_ATTEMPTS=6
HTTP_REQUEST_TIMEOUT_SECONDS=10
# Worker actor 总执行时长上限（秒）。设得宽松一点，作为 httpx 之外的兜底；
# 如果命中，actor 会被强制中止，可能留下 stuck delivering 任务需要人工处理。
ACTOR_TIME_LIMIT_SECONDS=30
MAX_PAYLOAD_BYTES=65536

# Provider credentials
PROVIDER_CRM_API_KEY=dev-crm-key
PROVIDER_CRM_BASE_URL=https://crm.vendor.test
PROVIDER_ADS_BEARER_TOKEN=dev-ads-token
PROVIDER_ADS_BASE_URL=https://ads.vendor.test
PROVIDER_INVENTORY_API_KEY=dev-inventory-key
PROVIDER_INVENTORY_BASE_URL=https://inventory.vendor.test
