# API
APP_ENV=local
API_KEY=dev-api-key
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/notifications
REDIS_URL=redis://localhost:6379/0
DEFAULT_MAX_ATTEMPTS=6
HTTP_REQUEST_TIMEOUT_SECONDS=10
MAX_PAYLOAD_BYTES=65536

